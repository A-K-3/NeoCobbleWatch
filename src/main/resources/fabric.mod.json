{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "version": "${version}",
  "name": "${mod_name}",
  "description": "Snapshots Cobblemon server data (pokédex, party, PC, stats) and exposes it via HTTP for a companion web frontend.",
  "authors": ["Ak"],
  "license": "All Rights Reserved",
  "environment": "*",
  "entrypoints": {
    "main": [
      {
        "adapter": "kotlin",
        "value": "ak.neocobblewatch.Neocobblewatch"
      }
    ]
  },
  "depends": {
    "fabricloader": ">=0.16.0",
    "fabric-language-kotlin": ">=1.13.0",
    "minecraft": "~1.21.1",
    "java": ">=21",
    "cobblemon": ">=1.7.3"
  }
}
